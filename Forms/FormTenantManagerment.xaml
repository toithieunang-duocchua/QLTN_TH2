<UserControl x:Class="QLTN.Forms.FormTenantManagerment"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QLTN.Forms"
             mc:Ignorable="d" 
             Width="774" Height="576">
    <UserControl.Resources>
        <!--  Bo góc cho TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="8"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer Margin="0"
                                      x:Name="PART_ContentHost"
                                      VerticalScrollBarVisibility="Hidden"
                                      HorizontalScrollBarVisibility="Hidden"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#ccc"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"/>

                            <!-- Nội dung hiển thị -->
                            <ContentPresenter Margin="10,0,35,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"/>

                            <!-- Nút mũi tên -->
                            <ToggleButton Grid.Column="2"
                                      Focusable="false"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      HorizontalAlignment="Right"
                                      Width="35">
                                <Path Data="M 0 0 L 2 2 L 4 0 Z"
                                  Fill="#666"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" Height="4" Width="6"/>
                            </ToggleButton>

                            <!-- Danh sách khi bấm -->
                            <Popup Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide"
                                Width="232">
                                <Border CornerRadius="8"
                                    Background="White"
                                    BorderBrush="#ccc"
                                    BorderThickness="1">
                                    <ScrollViewer Margin="4,6"
                                              SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#6A5ACD"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="0"
                            Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CenteredText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </UserControl.Resources>

    <Grid Background="#6A5ACD">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="90"/>
            <!-- Border 0: Header -->
            <RowDefinition Height="Auto" MinHeight="80"/>
            <!-- Border 1: Search -->
            <RowDefinition Height="1*" MinHeight="200"/>
        </Grid.RowDefinitions>

        <!-- Border trên -->
        <Border Grid.Row="0"
                CornerRadius="16"
                Background="White"
                Padding="16"
                Margin="16,10,16,16">
            <StackPanel VerticalAlignment="Center">
                <!-- Header -->
                <TextBlock Text=" Quản lý Người thuê"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="Black"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Quản lý thông tin người thuê và vân tay"
                           FontSize="15"
                           Foreground="#968E8E"
                           Margin="10,5,0,0"/>
            </StackPanel>
        </Border>
        <!-- Border 1: Search -->
        <Border Grid.Row="1"
                CornerRadius="16"
                Background="#fff"
                Padding="16"
                Margin="16,10,16,10"
                VerticalAlignment="Top">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,10,0">
                    <TextBox x:Name="SearchBox"
                        Height="40"
                        FontSize="16"
                        Padding="10"
                        BorderBrush="#ccc"
                        BorderThickness="1"
                        Foreground="#444"
                        Background="White"
                        VerticalAlignment="Center" Margin="0,0,10,0" TextChanged="SearchBox_TextChanged_1"/>

                    <TextBlock x:Name="Placeholder"
                        Text="Tìm kiếm theo tên, SDT,..."
                        Foreground="#888"
                        FontSize="16"
                        Padding="10,12,0,0"
                        IsHitTestVisible="False"
                        Visibility="Visible"
                        VerticalAlignment="Center" Margin="0,0,38,0"/>
                </Grid>

                <ComboBox Grid.Column="1" Width="200" Height="40" SelectedIndex="-1" VerticalAlignment="Center" Margin="0,0,10,0">
                    <ComboBoxItem Content="Tất cả phòng"/>
                    <ComboBoxItem Content="101"/>
                    <ComboBoxItem Content="102"/>
                    <ComboBoxItem Content="103"/>
                </ComboBox>

                <Button Grid.Column="2" Content="Thêm người thuê" Width="144" Height="40" Background="#6A5ACD" Foreground="White" FontSize="16" VerticalAlignment="Center"/>
            </Grid>
        </Border>
        <!-- Border 2: Table -->
        <Border Grid.Row="2"
                CornerRadius="16"
                Background="White"
                Padding="16"
                Margin="16,10,16,10"
                VerticalAlignment="Stretch">
            <DataGrid 
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeColumns="False"
                      IsReadOnly="True"
                      RowHeight="56"
                      GridLinesVisibility="None"
                      Background="Transparent"
                      BorderThickness="0"
                      VerticalAlignment="Stretch"
                      ItemsSource="{Binding NguoiThueList}"
                      Margin="6,10,-6,0" 
>

                <DataGrid.Resources>
                    <!-- Header -->
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Foreground" Value="#333"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>

                    <!-- Hàng -->
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Margin" Value="0,4"/>
                        <Setter Property="Padding" Value="6,0"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect BlurRadius="5" ShadowDepth="0" Opacity="0.1"/>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Cursor" Value="Hand"/>

                        <!-- Khi hover -->
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0F2FF"/>
                            </Trigger>

                            <!-- Khi được chọn -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#CCE4FF"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                </DataGrid.Resources>

                <!-- Cột -->
                <DataGrid.Columns>

                    <!-- Cột NGƯỜI THUÊ -->
                    <DataGridTemplateColumn Header="NGƯỜI THUÊ" Width="0.6*">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>

                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Ten}"
                       FontSize="13"
                       Foreground="#333"
                       VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Các cột còn lại -->
                    <DataGridTextColumn Header="PHÒNG"
                Binding="{Binding Phong}"
                Width="0.4*"
                ElementStyle="{StaticResource CenteredText}" />

                    <DataGridTextColumn Header="SỐ ĐIỆN THOẠI"
                Binding="{Binding SDT}"
                Width="0.7*"
                ElementStyle="{StaticResource CenteredText}" />

                    <!-- Cột TRẠNG THÁI VÂN TAY -->
                    <DataGridTemplateColumn Header="TRẠNG THÁI VÂN TAY" Width="1*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="15"
                            Padding="10,4"
                            Height="30"
                            Background="{Binding MauTrangThai}"
                            HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding TrangThai}"
                       Foreground="White"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       FontSize="14"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Cột HỢP ĐỒNG -->
                    <DataGridTemplateColumn Header="HỢP ĐỒNG" Width="1*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="15"
        Background="{Binding MauHopDong}"
        HorizontalAlignment="Center"
        Padding="10,4"
        Height="30">
                                    <TextBlock Text="{Binding HopDong}"
               Foreground="{Binding MauChuHopDong}"
               FontWeight="SemiBold"
               FontSize="13"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

    </Grid>
</UserControl>